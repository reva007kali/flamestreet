{
  "expo": {
    "name": "flamestreet",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/flamestreet-logo.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050807",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/flamestreet-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#050807"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#050807"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.flamestreet.mobile",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/flamestreet-logo.png",
        "backgroundColor": "#050807"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "androidStatusBar": {
      "backgroundColor": "#050807",
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#050807",
      "barStyle": "light-content"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "./plugins/withGradleWrapperNetworkTimeout.js",
        {
          "networkTimeout": 600000,
          "useCdn": false
        }
      ],
      [
        "./plugins/withAndroidCleartextTraffic.js",
        true
      ],
      "expo-dev-client",
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications",
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "4f25a0ee-9ed3-4e75-8783-9a3429741ed3"
      }
    },
    "owner": "reva007kali"
  }
}
